TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Neon Cloud Postgres Configuration
NEON_DB_HOST=ep-your-database-host.ap-southeast-1.aws.neon.tech
NEON_DB_USER=your_db_owner_username
NEON_DB_PASSWORD=your_db_password
NEON_DB_NAME=ecommerce_dw
NEON_DB_PORT=5432

# MinIO S3 Credentials
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Optional: Neon API Credentials for dynamic quota checking
# If not provided, seeder defaults to assuming a 512MB free tier limit
# NEON_API_KEY=your_neon_api_key
# NEON_PROJECT_ID=your_neon_project_id